#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PI_AGENT_CONTROL_ROOT="${PI_AGENT_CONTROL_ROOT:-$ROOT}"
cmd="${1:-help}"; shift || true
case "$cmd" in
  demo) prompt="$ROOT/prompts/demo.md" ;;
  verify) prompt="$ROOT/prompts/verify.md" ;;
  qa-test|qa) prompt="$ROOT/prompts/qa-test.md" ;;
  doctor) exec "$ROOT/scripts/doctor.sh" ;;
  skills) find "$ROOT/.agents/skills" -maxdepth 2 -name SKILL.md | sort ; exit 0 ;;
  help|-h|--help) echo "usage: $(basename "$0") demo|verify|qa-test|doctor|skills [arguments]"; exit 0 ;;
  *) echo "unknown command: $cmd" >&2; exit 2 ;;
esac
args="$*"
if command -v pi >/dev/null 2>&1; then
  if [ "pi" = "codex" ]; then
    exec codex exec "$(cat "$prompt")

Arguments: $args"
  else
    exec pi -p "$(cat "$prompt")

Arguments: $args"
  fi
else
  cat "$prompt"
  echo
  echo "Arguments: $args"
fi
