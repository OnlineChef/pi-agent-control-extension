{
  "name": "pi-agent-control-extension",
  "version": "5.0.0",
  "description": "Pi extension for terminal/CLI/browser control workflows: routing, capture, compose, verify, QA proofs, and showcase demos",
  "type": "module",
  "keywords": ["pi-package", "pi-extension", "terminal-automation", "tui", "qa", "showcase"],
  "license": "MIT",
  "scripts": {
    "validate": "py -3 scripts/validate-package.py || python3 scripts/validate-package.py || python scripts/validate-package.py",
    "check": "pi --offline --no-session --no-tools --no-skills --no-prompt-templates --no-extensions -e ./extensions/pi-control/index.ts --list-models does-not-exist-xyz",
    "pack:dry": "npm pack --dry-run"
  },
  "pi": {
    "extensions": ["./extensions/pi-control/index.ts"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "files": [
    "README.md",
    "CHANGELOG-v4.md",
    "extensions",
    "skills",
    "scripts",
    "artifacts/demo/demo.gif"
  ]
}
